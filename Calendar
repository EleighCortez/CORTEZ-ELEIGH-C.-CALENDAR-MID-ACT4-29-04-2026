class Calendar:
    def __init__(self):
        self.events = {}

    def is_leap_year(self, year):
        return year % 4 == 0

    def get_days_in_month(self, year, month):
        match month:
            case 1: return 31
            case 2: return 29 if self.is_leap_year(year) else 28
            case 3: return 31
            case 4: return 30
            case 5: return 31
            case 6: return 30
            case 7: return 31
            case 8: return 31
            case 9: return 30
            case 10: return 31
            case 11: return 30
            case 12: return 31
            case _: return -1

    def get_month_name(self, month):
        match month:
            case 1: return 'January'
            case 2: return 'February'
            case 3: return 'March'
            case 4: return 'April'
            case 5: return 'May'
            case 6: return 'June'
            case 7: return 'July'
            case 8: return 'August'
            case 9: return 'September'
            case 10: return 'October'
            case 11: return 'November'
            case 12: return 'December'
            case _: return 'Unknown'

    def is_valid_date(self, day, month, year):
        if year < 2026 or year > 2028:
            print("[ERROR] Year must be between 2026 and 2028 only!")
            return False
        if month < 1 or month > 12:
            print("[ERROR] Month must be between 1 and 12 only!")
            return False
        max_days = self.get_days_in_month(year, month)
        if day < 1 or day > max_days:
            print(f"[ERROR] Day must be between 1 {max_days} for {self.get_month_name(month)} {year}!")
            return False
        return True

    def add_event(self, day, month, year, name):
        if self.is_valid_date(day, month, year):
            date_key = (day, month, year)
            self.events[date_key] = name
            print(f"Event '{name}' added on {day} {self.get_month_name(month)} {year}!")

    def view_events_on_date(self, day, month, year):
        date_key = (day, month, year)
        if date_key in self.events:
            print(f"Events on {day} {self.get_month_name(month)} {year}: {self.events[date_key]}!")
        else:
            print("No events found")

    def view_all_events(self):
        if not self.events:
            print("No events scheduled.")
        else:
            for (day, month, year), name in self.events.items():
                print(f"Event {day} {self.get_month_name(month)} {year}: {name}!")

    def delete_event(self, day, month, year):
        date_key = (day, month, year)
        if date_key in self.events:
            removed = self.events.pop(date_key)
            print(f"Event '{removed}' deleted")
        else:
            print("No events found on that date")


cal = Calendar()

while True:
    print('\n MAIN MENU ')
    print("1. Add an Event")
    print("2. View an Event")
    print("3. View all Events")
    print("4. Delete an Event")
    print("5. Exit")

    choice = input("Enter your choice (1-5): ")

    if choice == '1':
        day = int(input("Enter day: "))
        month = int(input("Enter month: "))
        year = int(input("Enter year: "))
        name = input("Enter event name: ")
        cal.add_event(day, month, year, name)

    elif choice == '2':
        day = int(input("Enter day: "))
        month = int(input("Enter month: "))
        year = int(input("Enter year: "))
        cal.view_events_on_date(day, month, year)

    elif choice == '3':
        cal.view_all_events()

    elif choice == '4':
        day = int(input("Enter day: "))
        month = int(input("Enter month: "))
        year = int(input("Enter year: "))
        cal.delete_event(day, month, year)

    elif choice == '5':
        print("Exiting calendar. Goodbye!")
        break

    else:
        print("Invalid choice, please try again.")



